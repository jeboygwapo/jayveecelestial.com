  "Microsoft Azure":   { slug: "microsoftazure",   color: "0078D4" },
  "IBM Cloud":         { slug: "ibm",              color: "052FAD" },
};

function toKebab(title: string): string {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
